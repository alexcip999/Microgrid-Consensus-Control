        {
          "name": "Register - ADMIN",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.test('Has token', () => pm.expect(pm.response.json().token).to.be.a('string'));",
              "pm.test('Role ADMIN', () => pm.expect(pm.response.json().role).to.eql('ADMIN'));",
              "const r = pm.response.json();",
              "pm.collectionVariables.set('token', r.token);",
              "pm.collectionVariables.set('userId', r.userId);"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@microgrid.com\",\n  \"password\": \"password123\",\n  \"role\": \"ADMIN\"\n}" }
