    {
      "name": "── 03  GRID ────────────────────────────────────────",
      "item": [
        {
          "name": "Create grid - PHASE_1 RING",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.test('Name correct', () => pm.expect(pm.response.json().name).to.eql('Microgrid Alpha'));",
              "pm.test('Phase PHASE_1', () => pm.expect(pm.response.json().phase).to.eql('PHASE_1'));",
              "pm.test('Topology RING', () => pm.expect(pm.response.json().topology).to.eql('RING'));",
              "pm.test('fNom 60', () => pm.expect(pm.response.json().fNom).to.eql(60.0));",
              "pm.collectionVariables.set('gridId', pm.response.json().id);"
