{
  "info": {
    "name": "Microgrid Backend - Complete",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8081" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "gridId", "value": "" },
    { "key": "inverterId1", "value": "" },
    { "key": "inverterId2", "value": "" },
    { "key": "simulationId", "value": "" }
  ],
  "item": [

    {
      "name": "── 01  HEALTH ──────────────────────────────────────",
      "item": [
        {
          "name": "Health check",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Status ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
            ]}
          }],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        }
      ]
    },

    {
